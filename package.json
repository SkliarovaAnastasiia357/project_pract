{
  "name": "project_pract",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.2.0",
  "type": "module",
  "engines": {
    "node": "22.19.x",
    "npm": "11.2.x"
  },
  "scripts": {
    "dev": "vite",
