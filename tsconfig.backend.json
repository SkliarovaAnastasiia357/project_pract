{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src/backend",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["src/backend/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/backend/**/*.test.ts"]
}
